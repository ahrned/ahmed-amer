<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>b7e alaha 7eoo | حاسبة السعرات</title>
    <style>
        :root {
            --primary-color: #ff6600;
            --bg-dark: #121212;
            --card-bg: #1e1e1e;
            --text-light: #e0e0e0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            margin: 0;
            padding: 20px;
        }

        header {
            text-align: center;
            padding: 20px;
            border-bottom: 2px solid var(--primary-color);
            margin-bottom: 30px;
        }

        h1 { color: var(--primary-color); margin: 0; }

        .container { max-width: 900px; margin: auto; }

        /* الحاسبة */
        .calculator-section {
            background: var(--card-bg);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(255, 102, 0, 0.2);
            margin-bottom: 40px;
        }

        .input-group {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        label { display: block; margin-bottom: 5px; color: var(--primary-color); }

        input, select {
            width: 100%;
            padding: 10px;
            background: #333;
            border: 1px solid #444;
            color: white;
            border-radius: 5px;
        }

        button {
            width: 100%;
            padding: 12px;
            background: var(--primary-color);
            border: none;
            color: white;
            font-weight: bold;
            cursor: pointer;
            border-radius: 5px;
            font-size: 1.1rem;
        }

        #result {
            margin-top: 20px;
            text-align: center;
            font-size: 1.2rem;
            display: none;
            color: #fff;
            padding: 15px;
            border: 1px dashed var(--primary-color);
        }

        /* الجداول */
        .table-container {
            margin-top: 30px;
            overflow-x: auto;
        }

        h2 { color: var(--primary-color); border-right: 5px solid var(--primary-color); padding-right: 10px; }

        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--card-bg);
            margin-bottom: 30px;
        }

        th, td {
            padding: 12px;
            text-align: center;
            border: 1px solid #333;
        }

        th { background: var(--primary-color); color: black; }

        tr:nth-child(even) { background: #252525; }

        .note { font-size: 0.8rem; color: #888; margin-top: -20px; margin-bottom: 20px; }
    </style>
</head>
<body>

<header>
    <h1>b7e alaha 7eoo</h1>
    <p>دليلك العلمي لحساب السعرات الغذائية</p>
</header>

<div class="container">

    <section class="calculator-section">
        <h2>أولاً: احسب احتياجك اليومي (BMR)</h2>
        <div class="input-group">
            <div>
                <label>الوزن (كجم)</label>
                <input type="number" id="weight" placeholder="مثلاً: 70">
            </div>
            <div>
                <label>الطول (سم)</label>
                <input type="number" id="height" placeholder="مثلاً: 170">
            </div>
            <div>
                <label>العمر</label>
                <input type="number" id="age" placeholder="مثلاً: 25">
            </div>
            <div>
                <label>الجنس</label>
                <select id="gender">
                    <option value="male">ذكر</option>
                    <option value="female">أنثى</option>
                </select>
            </div>
        </div>
        <button onclick="calculateCalories()">احسب السعرات الآن</button>
        <div id="result"></div>
    </section>

    <h2>ثانياً: جداول السعرات (لكل 100 جرام)</h2>
    <p class="note">* قد تختلف الأرقام قليلاً حسب طريقة الطبخ (سلق، شوي، قلي).</p>

    <h3>1. النشويات والكربوهيدرات</h3>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>الصنف</th>
                    <th>قبل الطبخ (خام)</th>
                    <th>بعد الطبخ (مسلوق)</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>أرز أبيض</td><td>360 سعرة</td><td>130 سعرة (يتشرب الماء)</td></tr>
                <tr><td>معكرونة</td><td>370 سعرة</td><td>158 سعرة</td></tr>
                <tr><td>عدس</td><td>350 سعرة</td><td>116 سعرة</td></tr>
                <tr><td>بطاطس</td><td>77 سعرة</td><td>87 سعرة (مشوية)</td></tr>
                <tr><td>شوفان</td><td>389 سعرة</td><td>68 سعرة (مع ماء)</td></tr>
            </tbody>
        </table>
    </div>

    <h3>2. البروتينات</h3>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>الصنف</th>
                    <th>قبل الطبخ (نيئ)</th>
                    <th>بعد الطبخ (ناضج)</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>صدر دجاج</td><td>110 سعرة</td><td>165 سعرة (يفقد الماء)</td></tr>
                <tr><td>لحم بقري (قليل الدسم)</td><td>150 سعرة</td><td>250 سعرة</td></tr>
                <tr><td>سمك سلمون</td><td>200 سعرة</td><td>240 سعرة</td></tr>
                <tr><td>بيض (بيضة واحدة)</td><td>70 سعرة (خام)</td><td>78 سعرة (مسلوقة)</td></tr>
            </tbody>
        </table>
    </div>

    <h3>3. الحلويات</h3>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>الصنف</th>
                    <th>الكمية</th>
                    <th>السعرات التقريبية</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>بقلاوة</td><td>قطعة واحدة</td><td>150 - 200 سعرة</td></tr>
                <tr><td>كنافة</td><td>100 جرام</td><td>350 - 450 سعرة</td></tr>
                <tr><td>شوكولاتة داكنة</td><td>100 جرام</td><td>550 سعرة</td></tr>
                <tr><td>بسبوسة</td><td>قطعة متوسطة</td><td>250 سعرة</td></tr>
            </tbody>
        </table>
    </div>

</div>

<script>
    function calculateCalories() {
        const weight = parseFloat(document.getElementById('weight').value);
        const height = parseFloat(document.getElementById('height').value);
        const age = parseInt(document.getElementById('age').value);
        const gender = document.getElementById('gender').value;
        const resultDiv = document.getElementById('result');

        if (!weight || !height || !age) {
            alert("يرجى إدخال جميع البيانات بشكل صحيح");
            return;
        }

        // معادلة Mifflin-St Jeor
        let bmr;
        if (gender === "male") {
            bmr = (10 * weight) + (6.25 * height) - (5 * age) + 5;
        } else {
            bmr = (10 * weight) + (6.25 * height) - (5 * age) - 161;
        }

        // متوسط السعرات للمحافظة على الوزن (نشاط متوسط خفيف)
        const tdee = Math.round(bmr * 1.2);

        resultDiv.style.display = "block";
        resultDiv.innerHTML = `
            <strong>النتيجة:</strong><br>
            معدل الأيض الأساسي (BMR): <strong>${Math.round(bmr)}</strong> سعرة.<br>
            يحتاج جسمك حوالي <strong>${tdee}</strong> سعرة يومياً للمحافظة على وزنك الحالي.
        `;
    }
</script>

</body>
</html>
